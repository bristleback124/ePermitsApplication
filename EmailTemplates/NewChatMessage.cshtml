@model ePermitsApp.Models.EmailModels.NewChatMessageModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 0 auto; }
        .header { background-color: #1a56db; color: white; padding: 20px; text-align: center; }
        .header h1 { margin: 0; font-size: 24px; }
        .content { padding: 30px 20px; background-color: #f9fafb; }
        .content h2 { color: #1a56db; margin-top: 0; }
        .details { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; margin: 20px 0; }
        .details p { margin: 8px 0; }
        .label { font-weight: bold; color: #374151; }
        .message-box { background-color: #f3f4f6; border-left: 4px solid #1a56db; padding: 12px 16px; margin: 12px 0; border-radius: 0 4px 4px 0; }
        .message-box p { margin: 0; color: #4b5563; }
        .footer { padding: 15px 20px; text-align: center; font-size: 12px; color: #6b7280; background-color: #f3f4f6; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>ePermits</h1>
        </div>
        <div class="content">
            <h2>New Message on Your Application</h2>
            <p>Dear @Model.RecipientName,</p>
            <p>You have received a new message on your <strong>@Model.ApplicationType</strong> application.</p>

            <div class="details">
                <p><span class="label">Reference Number:</span> @Model.ApplicationFormattedId</p>
                <p><span class="label">From:</span> @Model.SenderName (@Model.SenderRole)</p>
                <p><span class="label">Date:</span> @Model.SentAt.ToString("MMMM dd, yyyy hh:mm tt")</p>
                <p><span class="label">Message:</span></p>
                <div class="message-box">
                    <p>@Model.MessagePreview</p>
                </div>
            </div>

            <p>Please log in to the ePermits portal to view the full conversation and reply.</p>
            <p>If you have any questions, please contact your administrator.</p>
        </div>
        <div class="footer">
            <p>&copy; @DateTime.Now.Year ePermits System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
