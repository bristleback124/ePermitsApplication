@model ePermitsApp.Models.EmailModels.ApplicantCredentialsModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 0 auto; }
        .header { background-color: #1a56db; color: white; padding: 20px; text-align: center; }
        .header h1 { margin: 0; font-size: 24px; }
        .content { padding: 30px 20px; background-color: #f9fafb; }
        .content h2 { color: #1a56db; margin-top: 0; }
        .details { background-color: #ffffff; border: 2px solid #1a56db; border-radius: 8px; padding: 24px; margin: 20px 0; }
        .details .row { margin: 14px 0; }
        .details .row:first-child { margin-top: 0; }
        .details .row:last-child { margin-bottom: 0; }
        .details .label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; margin-bottom: 4px; }
        .details .value { display: block; font-family: 'Courier New', monospace; font-size: 18px; font-weight: bold; color: #1e3a8a; word-break: break-all; }
        .meta { color: #6b7280; font-size: 13px; margin: 18px 0 0; }
        .applicant-info { background-color: #f3f4f6; border-radius: 6px; padding: 12px 16px; margin: 16px 0; font-size: 14px; color: #374151; }
        .applicant-info strong { color: #111827; }
        .notice { background-color: #fff7ed; border-left: 4px solid #f59e0b; padding: 12px 16px; margin: 20px 0; color: #78350f; font-size: 14px; }
        .footer { padding: 15px 20px; text-align: center; font-size: 12px; color: #6b7280; background-color: #f3f4f6; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>ePermits</h1>
        </div>
        <div class="content">
            <h2>Applicant Registration Confirmation</h2>
            <p>Dear @Model.EncoderName,</p>
            <p>You have successfully registered <strong>@Model.ApplicantName</strong>. A welcome email has also been sent to the applicant with the login credentials below.</p>

            <div class="applicant-info">
                <strong>Applicant:</strong> @Model.ApplicantName
            </div>

            <p style="margin-bottom: 6px;"><strong>Login credentials (email + password):</strong></p>
            <div class="details">
                <div class="row">
                    <span class="label">Email</span>
                    <span class="value">@Model.ApplicantEmail</span>
                </div>
                <div class="row">
                    <span class="label">Temporary Password</span>
                    <span class="value">@Model.TempPassword</span>
                </div>
            </div>

            <p class="meta">Registered on @Model.RegisteredAt.ToString("MMMM dd, yyyy hh:mm tt")</p>

            <div class="notice">
                <strong>Reminder:</strong> Share these credentials with the applicant through a secure channel only if they do not receive their welcome email. The applicant will be required to change the temporary password on first login.
            </div>
        </div>
        <div class="footer">
            <p>&copy; @DateTime.Now.Year ePermits System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
